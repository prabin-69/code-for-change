# ────────────────────────────────────────────────────────────────────────────
# Sewaghar Backend — Environment Variables
# Copy this file to .env and fill in the values before running the server.
# NEVER commit .env to version control.
# ────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4000

# PostgreSQL (PostGIS required for location features)
DATABASE_URL=postgresql://marketplace:changeme@localhost:5432/marketplace

# Redis
REDIS_URL=redis://localhost:6379

# JWT – use strong random secrets (minimum 32 characters each)
JWT_ACCESS_SECRET=change_me_to_a_very_long_random_string_at_least_32
JWT_REFRESH_SECRET=change_me_to_another_very_long_random_string_at_least_32
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Twilio (SMS OTP) – Requires Manual Verification
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# S3 / Cloudflare R2 (file storage) – Requires Manual Verification
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=
S3_BUCKET=

# Frontend URLs (CORS whitelist)
CLIENT_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# eSewa Payment Gateway – Requires Manual Verification
ESEWA_BASE_URL=https://uat.esewa.com.np
ESEWA_MERCHANT_CODE=
ESEWA_SECRET_KEY=

# Khalti Payment Gateway – Requires Manual Verification
KHALTI_BASE_URL=https://a.khalti.com/api/v2
KHALTI_SECRET_KEY=

# Bank Transfer Details
BANK_NAME=
BANK_ACCOUNT=
BANK_ACCOUNT_HOLDER=
BANK_QR_BASE_URL=

# Firebase Admin SDK – JSON-stringified service account key (Requires Manual Verification)
# Run: cat your-service-account.json | jq -c . | sed 's/"/\\"/g'
FIREBASE_SERVICE_ACCOUNT=
